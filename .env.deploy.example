# Copy to .env.deploy.production or .env.deploy.development and fill in.
# Both files are gitignored — never commit real values.
#
# Note: most production releases happen via .github/workflows/release.yml on tag push.
# This file is for running goreleaser locally (e.g. dry-run snapshots).

# GitHub PAT with repo scope. Required for production releases.
# Generate at https://github.com/settings/tokens
GITHUB_TOKEN=

# --- Docker Hub (optional — only if you add a `dockers:` section to .goreleaser.yaml) ---
# DOCKERHUB_USERNAME=piyushgambhir
# DOCKERHUB_TOKEN=
